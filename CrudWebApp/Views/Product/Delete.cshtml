@model CrudWebApp.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-trash me-2 text-danger"></i>Delete Product</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-1"></i>Back to Products
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5><i class="fas fa-exclamation-triangle me-2"></i>Confirm Deletion</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="fas fa-warning me-2"></i>
                    <strong>Warning:</strong> This action cannot be undone. Are you sure you want to delete this product?
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <h6>Product Name</h6>
                        <p class="fw-bold">@Model.Name</p>
                    </div>
                    <div class="col-md-6">
                        <h6>Category</h6>
                        <p><span class="badge bg-secondary">@Model.Category</span></p>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <h6>Price</h6>
                        <p class="text-success fw-bold">@Model.Price.ToString("C")</p>
                    </div>
                    <div class="col-md-6">
                        <h6>Quantity</h6>
                        <p>@Model.Quantity units</p>
                    </div>
                </div>
                
                <h6>Description</h6>
                <p class="text-muted">@Model.Description</p>
                
                <hr>
                
                <div class="row">
                    <div class="col-md-6">
                        <h6>Created</h6>
                        <p>@Model.CreatedDate.ToString("MMMM dd, yyyy")</p>
                    </div>
                    <div class="col-md-6">
                        <h6>Last Modified</h6>
                        <p>@Model.LastModified.ToString("MMMM dd, yyyy")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card border-info">
            <div class="card-header bg-info text-white">
                <h6><i class="fas fa-info-circle me-2"></i>Product Summary</h6>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <h4>@Model.Name</h4>
                    <p class="text-muted">ID: #@Model.Id</p>
                </div>
                
                <div class="bg-light p-3 rounded text-center">
                    <h6 class="text-muted mb-1">Total Value</h6>
                    <h4 class="text-success">@((Model.Price * Model.Quantity).ToString("C"))</h4>
                </div>
                
                <hr>
                
                <div class="text-center">
                    @if (Model.Quantity > 10)
                    {
                        <span class="badge bg-success fs-6">In Stock</span>
                    }
                    else if (Model.Quantity > 0)
                    {
                        <span class="badge bg-warning fs-6">Low Stock</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">Out of Stock</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times me-1"></i>Cancel
                        </a>
                        <div>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info btn-lg me-2">
                                <i class="fas fa-eye me-1"></i>View Details
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="fas fa-trash me-1"></i>Yes, Delete Product
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>