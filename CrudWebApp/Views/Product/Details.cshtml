@model CrudWebApp.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-info-circle me-2"></i>Product Details</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-1"></i>Back to Products
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4>@Model.Name</h4>
                <span class="badge bg-secondary">@Model.Category</span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6><i class="fas fa-tag me-2"></i>Price</h6>
                        <p class="text-success fs-4 fw-bold">@Model.Price.ToString("C")</p>
                    </div>
                    <div class="col-md-6">
                        <h6><i class="fas fa-boxes me-2"></i>Stock</h6>
                        @if (Model.Quantity > 0)
                        {
                            <p class="text-success fs-5">@Model.Quantity units available</p>
                        }
                        else
                        {
                            <p class="text-danger fs-5">Out of stock</p>
                        }
                    </div>
                </div>
                
                <hr>
                
                <h6><i class="fas fa-align-left me-2"></i>Description</h6>
                <p class="text-muted">@Model.Description</p>
                
                <hr>
                
                <div class="row">
                    <div class="col-md-6">
                        <h6><i class="fas fa-calendar-plus me-2"></i>Created Date</h6>
                        <p>@Model.CreatedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
                    </div>
                    <div class="col-md-6">
                        <h6><i class="fas fa-calendar-edit me-2"></i>Last Modified</h6>
                        <p>@Model.LastModified.ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6><i class="fas fa-tools me-2"></i>Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="fas fa-edit me-1"></i>Edit Product
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Delete Product
                    </a>
                    <a asp-action="Create" class="btn btn-success">
                        <i class="fas fa-plus me-1"></i>Add New Product
                    </a>
                </div>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <h6><i class="fas fa-chart-bar me-2"></i>Product Stats</h6>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-12 mb-3">
                        <div class="bg-light p-3 rounded">
                            <h6 class="text-muted mb-1">Total Value</h6>
                            <h4 class="text-success">@((Model.Price * Model.Quantity).ToString("C"))</h4>
                        </div>
                    </div>
                </div>
                <div class="row text-center">
                    <div class="col-6">
                        <div class="bg-light p-2 rounded">
                            <small class="text-muted">Status</small>
                            @if (Model.Quantity > 10)
                            {
                                <p class="text-success mb-0"><i class="fas fa-check-circle"></i> In Stock</p>
                            }
                            else if (Model.Quantity > 0)
                            {
                                <p class="text-warning mb-0"><i class="fas fa-exclamation-triangle"></i> Low Stock</p>
                            }
                            else
                            {
                                <p class="text-danger mb-0"><i class="fas fa-times-circle"></i> Out of Stock</p>
                            }
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-light p-2 rounded">
                            <small class="text-muted">Product ID</small>
                            <p class="mb-0">#@Model.Id</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>