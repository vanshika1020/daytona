@{
    ViewData["Title"] = "About";
}

<h2><i class="fas fa-info-circle me-2"></i>About CRUD Web App</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <h5>Overview</h5>
                <p>This is a complete ASP.NET Core MVC application demonstrating CRUD (Create, Read, Update, Delete) operations for product management. The application showcases modern web development practices and responsive design.</p>
                
                <h5>Features</h5>
                <ul>
                    <li>Create new products with detailed information</li>
                    <li>View all products in a responsive table format</li>
                    <li>View detailed information for individual products</li>
                    <li>Update existing product information</li>
                    <li>Delete products with confirmation</li>
                    <li>Form validation for data integrity</li>
                    <li>Responsive design for mobile and desktop</li>
                </ul>
                
                <h5>Technologies Used</h5>
                <ul>
                    <li>ASP.NET Core 8.0</li>
                    <li>Entity Framework Core</li>
                    <li>Bootstrap 5</li>
                    <li>Font Awesome Icons</li>
                    <li>Razor Pages</li>
                    <li>In-Memory Database</li>
                </ul>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6><i class="fas fa-code me-2"></i>Development Info</h6>
            </div>
            <div class="card-body">
                <p><strong>Framework:</strong> ASP.NET Core 8.0</p>
                <p><strong>Database:</strong> In-Memory Database</p>
                <p><strong>UI Framework:</strong> Bootstrap 5</p>
                <p><strong>Icons:</strong> Font Awesome</p>
                <p><strong>IDE:</strong> Visual Studio 2022</p>
            </div>
        </div>
    </div>
</div>