@{
    ViewData["Title"] = "Contact";
}

<h2><i class="fas fa-envelope me-2"></i>Contact Us</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-paper-plane me-2"></i>Get in Touch</h5>
            </div>
            <div class="card-body">
                <form>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label for="name" class="form-label">Name</label>
                                <input type="text" class="form-control" id="name" placeholder="Your Name" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" placeholder="your@email.com" required>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label for="subject" class="form-label">Subject</label>
                        <input type="text" class="form-control" id="subject" placeholder="Message Subject" required>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label for="message" class="form-label">Message</label>
                        <textarea class="form-control" id="message" rows="5" placeholder="Your message here..." required></textarea>
                    </div>
                    
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-send me-1"></i>Send Message
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6><i class="fas fa-info-circle me-2"></i>Contact Information</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <h6><i class="fas fa-map-marker-alt me-2"></i>Address</h6>
                    <p class="text-muted">123 Tech Street<br>Developer City, DC 12345</p>
                </div>
                
                <div class="mb-3">
                    <h6><i class="fas fa-phone me-2"></i>Phone</h6>
                    <p class="text-muted">+1 (555) 123-4567</p>
                </div>
                
                <div class="mb-3">
                    <h6><i class="fas fa-envelope me-2"></i>Email</h6>
                    <p class="text-muted">contact@crudwebapp.com</p>
                </div>
                
                <div class="mb-3">
                    <h6><i class="fas fa-clock me-2"></i>Business Hours</h6>
                    <p class="text-muted">
                        Monday - Friday: 9:00 AM - 6:00 PM<br>
                        Saturday: 10:00 AM - 4:00 PM<br>
                        Sunday: Closed
                    </p>
                </div>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <h6><i class="fas fa-share-alt me-2"></i>Follow Us</h6>
            </div>
            <div class="card-body text-center">
                <a href="#" class="btn btn-outline-primary btn-sm me-2">
                    <i class="fab fa-twitter"></i> Twitter
                </a>
                <a href="#" class="btn btn-outline-primary btn-sm me-2">
                    <i class="fab fa-facebook"></i> Facebook
                </a>
                <a href="#" class="btn btn-outline-primary btn-sm">
                    <i class="fab fa-linkedin"></i> LinkedIn
                </a>
            </div>
        </div>
    </div>
</div>